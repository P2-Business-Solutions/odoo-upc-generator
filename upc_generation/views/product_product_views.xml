<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_product_form_upc" model="ir.ui.view">
        <field name="name">product.product.form.upc</field>
        <field name="model">product.product</field>
        <field name="inherit_id" ref="product.product_normal_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='barcode']" position="attributes">
                <attribute name="readonly">upc_generated</attribute>
            </xpath>
            <xpath expr="//field[@name='barcode']" position="after">
                <field name="upc_generated" readonly="1"/>
                <field name="barcode_source" readonly="1"/>
                <field name="upc_prefix_id" readonly="1"/>
                <field name="upc_ref" readonly="1"/>
                <field name="upc_assigned_on" readonly="1"/>
            </xpath>
        </field>
    </record>
</odoo>
