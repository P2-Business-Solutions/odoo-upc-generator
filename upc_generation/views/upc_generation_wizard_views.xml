<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_upc_generation_wizard_form" model="ir.ui.view">
        <field name="name">upc.generation.wizard.form</field>
        <field name="model">upc.generation.wizard</field>
        <field name="arch" type="xml">
            <form string="UPC Generation">
                <field name="state" invisible="1"/>
                <sheet>
                    <div class="oe_title">
                        <h1 invisible="state != 'preview'">Preview UPC Generation</h1>
                        <h1 invisible="state != 'done'">UPC Generation Complete</h1>
                    </div>
                    <group>
                        <group string="Active Prefix">
                            <field name="prefix_id" readonly="1"/>
                            <field name="prefix_display"/>
                            <field name="remaining_before"/>
                            <field name="remaining_after"/>
                        </group>
                        <group string="Summary">
                            <field name="eligible_count"/>
                            <field name="skip_existing_count"/>
                            <field name="skip_generated_count"/>
                            <field name="skip_other_count"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Details" name="lines">
                            <field name="line_ids" readonly="1">
                                <list string="Lines" create="0" delete="0" edit="0">
                                    <field name="product_id"/>
                                    <field name="default_code"/>
                                    <field name="current_barcode"/>
                                    <field name="status"/>
                                    <field name="generated_upc"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_generate"
                            string="Generate UPCs"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'preview' or eligible_count == 0"/>
                    <button string="Cancel"
                            class="btn-secondary"
                            special="cancel"
                            invisible="state != 'preview'"/>
                    <button string="Close"
                            class="btn-primary"
                            special="cancel"
                            invisible="state != 'done'"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
