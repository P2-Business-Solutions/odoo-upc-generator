<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_upc_prefix_tree" model="ir.ui.view">
        <field name="name">upc.prefix.list</field>
        <field name="model">upc.prefix</field>
        <field name="arch" type="xml">
            <list string="UPC Prefixes">
                <field name="name"/>
                <field name="prefix"/>
                <field name="is_active" widget="boolean_toggle"/>
                <field name="next_ref"/>
                <field name="capacity"/>
                <field name="remaining_count"/>
                <field name="company_id" optional="show" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_upc_prefix_form" model="ir.ui.view">
        <field name="name">upc.prefix.form</field>
        <field name="model">upc.prefix</field>
        <field name="arch" type="xml">
            <form string="UPC Prefix">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="e.g. Main Prefix"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="prefix" placeholder="e.g. 840012"/>
                            <field name="is_active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="capacity"/>
                            <field name="next_ref"/>
                            <field name="remaining_count"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_upc_prefix_search" model="ir.ui.view">
        <field name="name">upc.prefix.search</field>
        <field name="model">upc.prefix</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="prefix"/>
                <filter string="Active" name="filter_active" domain="[('is_active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_upc_prefix" model="ir.actions.act_window">
        <field name="name">UPC Prefixes</field>
        <field name="res_model">upc.prefix</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_upc_prefix_search"/>
    </record>

    <menuitem id="menu_upc_prefix"
              name="UPC Prefixes"
              parent="stock.menu_stock_config_settings"
              action="action_upc_prefix"
              sequence="90"/>
</odoo>
