<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_preview_upc_from_template" model="ir.actions.server">
        <field name="name">Preview UPC Generation</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="binding_model_id" ref="product.model_product_template"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
action = env['upc.generation.wizard'].with_context(
    active_model='product.template',
    active_ids=records.ids,
).action_open_wizard()
        </field>
    </record>

    <record id="action_preview_upc_from_product" model="ir.actions.server">
        <field name="name">Preview UPC Generation</field>
        <field name="model_id" ref="product.model_product_product"/>
        <field name="binding_model_id" ref="product.model_product_product"/>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">
action = env['upc.generation.wizard'].with_context(
    active_model='product.product',
    active_ids=records.ids,
).action_open_wizard()
        </field>
    </record>

    <record id="action_preview_upc_flagged_templates" model="ir.actions.server">
        <field name="name">UPC: Preview Generation for Flagged Templates</field>
        <field name="model_id" ref="product.model_product_template"/>
        <field name="state">code</field>
        <field name="code">
templates = env['product.template'].search([('generate_upc', '=', True)])
if not templates:
    raise UserError('No product templates are flagged with Generate UPC.')
action = env['upc.generation.wizard'].with_context(
    active_model='product.template',
    active_ids=templates.ids,
).action_open_wizard()
        </field>
    </record>
</odoo>
